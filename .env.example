# Configurações de ambiente para o Emacspeak Docker
# Copie este arquivo para .env e ajuste conforme necessário

# Servidor de fala TTS a ser usado
# Opções: espeak, espeak-socat (para relay TCP no macOS)
DTK_SPEECH_SERVER=espeak

# Versão do Emacspeak
EMACSPEAK_VERSION=60.0

# Diretório de cache de native compilation
EMACS_ELN_CACHE=/root/.emacs.d/eln-cache

# Porta para o servidor espeak-socat (apenas macOS)
ESPEAK_SOCAT_PORT=5500
